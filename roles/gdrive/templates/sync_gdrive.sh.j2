#!/bin/bash
{{ ansible_managed | comment }}

# Bidirectional sync pairs: local path <-> gdrive:remote (multiple roots)
# Cron runs rclone bisync (deletes and moves propagate both ways).
# Transmission hook uses one-way rclone copy for immediate upload.
REMOTE_NAME="{{ gdrive__remote_name }}"
LOG_FILE="${HOME}/rclone_sync.log"
GDRIVE_BISYNC_FORCE_RESYNC="${GDRIVE_BISYNC_FORCE_RESYNC:-{% if gdrive__bisync_force_resync | default(false) | bool %}1{% endif %}}"

# shellcheck disable=SC2034,SC2206
SYNC_LOCALS=( {% for p in gdrive__sync_pairs_resolved %}{{ p.local | to_json }} {% endfor %})
# shellcheck disable=SC2034,SC2206
SYNC_REMOTES=( {% for p in gdrive__sync_pairs_resolved %}{{ p.remote | to_json }} {% endfor %})
# shellcheck disable=SC2034,SC2206
REQUIRED_MOUNT_POINTS=( {% for p in gdrive__required_mount_points %}{{ p | to_json }} {% endfor %})

assert_required_mount_points() {
  local _mount
  for _mount in "${REQUIRED_MOUNT_POINTS[@]}"; do
    if ! findmnt -rn "$_mount" > /dev/null 2>&1; then
      echo "ERROR: required mount point is not mounted: $_mount" >&2
      exit 1
    fi
  done
}

# Pick pair index for TR_TORRENT_DIR (longest local prefix); echo index or -1
find_pair_index() {
  local tdir="${1:-}"
  tdir="${tdir%/}"
  local best_i=-1
  local best_len=0
  local i loc lnorm n
  for i in "${!SYNC_LOCALS[@]}"; do
    loc="${SYNC_LOCALS[$i]}"
    lnorm="${loc%/}"
    if [[ "$tdir" == "$lnorm" || "$tdir" == "$lnorm"/* ]]; then
      # Semicolon keeps the following if on this line (Ansible Jinja trim_blocks)
      n={% raw %}${#lnorm}{% endraw %}; if [[ $n -gt $best_len ]]; then
        best_len=$n
        best_i=$i
      fi
    fi
  done
  echo "$best_i"
}

run_rclone_copy() {
  local _src="$1"
  local _dst="$2"
  echo "Copying without deletion: $_src -> $_dst"
  rclone copy "$_src" "$_dst" \
    --transfers 4 \
    --checkers 8 \
    --exclude "*.part" \
    --log-file "$LOG_FILE" \
    --log-level INFO \
    --stats 60s \
    --stats-one-line
}

remote_dest_for_local_dir() {
  local _local_root="${1%/}"
  local _remote_root="${2%/}"
  local _dir="${3%/}"
  local _relative

  if [[ "$_dir" == "$_local_root" ]]; then
    echo "$REMOTE_NAME:$_remote_root"
    return
  fi

  _relative="${_dir#$_local_root/}"
  echo "$REMOTE_NAME:$_remote_root/$_relative"
}

run_rclone_bisync() {
  local _local="$1"
  local _rem="$2"
  local _pair_id="$3"
  local _workdir="${HOME}/.cache/rclone/bisync/${_pair_id}"
  local _resync_flag=()

  if [[ -n "$GDRIVE_BISYNC_FORCE_RESYNC" ]] || [[ ! -f "${_workdir}/.bisync_initialized" ]]; then
    _resync_flag=(--resync)
    echo "Bisync resync for pair $_pair_id (force=${GDRIVE_BISYNC_FORCE_RESYNC:-0}, initialized=$([[ -f "${_workdir}/.bisync_initialized" ]] && echo 1 || echo 0))"
  fi

  echo "Bisync: $_local <-> $REMOTE_NAME:$_rem"
  # Flags compatible with rclone bisync from Debian apt (~1.60); global flags apply to transfers.
  rclone bisync "$_local" "$REMOTE_NAME:$_rem" \
    "${_resync_flag[@]}" \
    --workdir "$_workdir" \
    --transfers 4 \
    --checkers 8 \
    --exclude "*.part" \
    --log-file "$LOG_FILE" \
    --log-level INFO \
    --stats 60s \
    --stats-one-line || return

  mkdir -p "$_workdir"
  touch "${_workdir}/.bisync_initialized"
}

assert_required_mount_points

# Transmission: copy finished torrent path to the matching gdrive root
if [[ -n "${TR_TORRENT_DIR:-}" ]]; then
  TORRENT_DIR="${TR_TORRENT_DIR%/}"
  SYNC_SRC="$TORRENT_DIR"
  echo "Copying finished torrent: ${TR_TORRENT_NAME:-unknown} ($TR_TORRENT_DIR)"
  echo "Timestamp: $(date)"
  pair_idx=$(find_pair_index "$TR_TORRENT_DIR")
  if [[ "$pair_idx" -lt 0 ]]; then
    echo "ERROR: TR_TORRENT_DIR is not under any gdrive__sync_pairs local path" >&2
    exit 1
  fi
  LOCAL_ROOT="${SYNC_LOCALS[$pair_idx]}"
  REM_DIR="${SYNC_REMOTES[$pair_idx]}"
  REM_DEST="$(remote_dest_for_local_dir "$LOCAL_ROOT" "$REM_DIR" "$TORRENT_DIR")"
  if [[ -n "${TR_TORRENT_NAME:-}" && -e "$TORRENT_DIR/$TR_TORRENT_NAME" ]]; then
    SYNC_SRC="$TORRENT_DIR/$TR_TORRENT_NAME"
  fi
  echo "Target remote: $REM_DEST (pair index $pair_idx)"
  run_rclone_copy "$SYNC_SRC" "$REM_DEST"
  echo "Copy finished: ${TR_TORRENT_NAME:-$SYNC_SRC} -> $REM_DEST"
else
  # Cron / manual: true bidirectional sync (deletes propagate both ways).
  echo "Starting bidirectional bisync for all pairs; timestamp: $(date)"
  for i in "${!SYNC_LOCALS[@]}"; do
    _loc="${SYNC_LOCALS[$i]}"
    _rem="${SYNC_REMOTES[$i]}"
    _pair_id="pair_${i}"
    echo "--- Pair $((i + 1))/{% raw %}${#SYNC_LOCALS[@]}{% endraw %}: $_loc <-> $REMOTE_NAME:$_rem"
    if ! run_rclone_bisync "$_loc" "$_rem" "$_pair_id"; then
      exit $?
    fi
  done
  echo "All bisync runs finished: $(date)"
fi
