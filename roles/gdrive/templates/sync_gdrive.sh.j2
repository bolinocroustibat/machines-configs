#!/bin/bash
{{ ansible_managed | comment }}

# Sync pairs: local path <-> gdrive:remote (multiple roots)
REMOTE_NAME="{{ gdrive__remote_name }}"
LOG_FILE="${HOME}/rclone_sync.log"

# shellcheck disable=SC2034,SC2206
SYNC_LOCALS=( {% for p in gdrive__sync_pairs_resolved %}{{ p.local | to_json }} {% endfor %})
# shellcheck disable=SC2034,SC2206
SYNC_REMOTES=( {% for p in gdrive__sync_pairs_resolved %}{{ p.remote | to_json }} {% endfor %})

# Pick pair index for TR_TORRENT_DIR (longest local prefix); echo index or -1
find_pair_index() {
  local tdir="${1:-}"
  tdir="${tdir%/}"
  local best_i=-1
  local best_len=0
  local i loc lnorm n
  for i in "${!SYNC_LOCALS[@]}"; do
    loc="${SYNC_LOCALS[$i]}"
    lnorm="${loc%/}"
    if [[ "$tdir" == "$lnorm" || "$tdir" == "$lnorm"/* ]]; then
      # Semicolon keeps the following if on this line (Ansible Jinja trim_blocks)
      n={% raw %}${#lnorm}{% endraw %}; if [[ $n -gt $best_len ]]; then
        best_len=$n
        best_i=$i
      fi
    fi
  done
  echo "$best_i"
}

run_bisync_or_sync() {
  local _local="$1"
  local _rem="$2"
  if rclone bisync --help > /dev/null 2>&1; then
    echo "Using rclone bisync: $_local <-> $REMOTE_NAME:$_rem"
    rclone bisync "$_local" "$REMOTE_NAME:$_rem" \
      --transfers 4 \
      --checkers 8 \
      --exclude "*.part" \
      --log-file "$LOG_FILE" \
      --log-level INFO \
      --stats 60s \
      --stats-one-line
    return
  else
    echo "bisync not available, using sync: $_local <-> $REMOTE_NAME:$_rem"
    rclone sync "$_local" "$REMOTE_NAME:$_rem" \
      --transfers 4 \
      --checkers 8 \
      --exclude "*.part" \
      --log-file "$LOG_FILE" \
      --log-level INFO \
      --stats 60s \
      --stats-one-line || return
    rclone sync "$REMOTE_NAME:$_rem" "$_local" \
      --transfers 4 \
      --checkers 8 \
      --exclude "*.part" \
      --log-file "$LOG_FILE" \
      --log-level INFO \
      --stats 60s \
      --stats-one-line
  fi
}

# Transmission: sync finished torrent path to the matching gdrive root
if [[ -n "${TR_TORRENT_DIR:-}" ]]; then
  SYNC_SRC="${TR_TORRENT_DIR}"
  echo "Syncing finished torrent: $TR_TORRENT_NAME ($TR_TORRENT_DIR)"
  echo "Timestamp: $(date)"
  pair_idx=$(find_pair_index "$TR_TORRENT_DIR")
  if [[ "$pair_idx" -lt 0 ]]; then
    echo "ERROR: TR_TORRENT_DIR is not under any gdrive__sync_pairs local path" >&2
    exit 1
  fi
  REM_DIR="${SYNC_REMOTES[$pair_idx]}"
  echo "Target remote: $REMOTE_NAME:$REM_DIR (pair index $pair_idx)"
  rclone sync "$SYNC_SRC" "$REMOTE_NAME:$REM_DIR" \
    --transfers 4 \
    --checkers 8 \
    --exclude "*.part" \
    --log-file "$LOG_FILE" \
    --log-level INFO \
    --stats 60s \
    --stats-one-line
  echo "Sync finished: $TR_TORRENT_NAME -> $REMOTE_NAME:$REM_DIR"
else
  # Cron / manual: bidirectional sync for each pair
  echo "Starting bidirectional sync for all pairs; timestamp: $(date)"
  for i in "${!SYNC_LOCALS[@]}"; do
    _loc="${SYNC_LOCALS[$i]}"
    _rem="${SYNC_REMOTES[$i]}"
    echo "--- Pair $((i + 1))/{% raw %}${#SYNC_LOCALS[@]}{% endraw %}: $_loc <-> $REMOTE_NAME:$_rem"
    if ! run_bisync_or_sync "$_loc" "$_rem"; then
      exit $?
    fi
  done
  echo "All syncs finished: $(date)"
fi
