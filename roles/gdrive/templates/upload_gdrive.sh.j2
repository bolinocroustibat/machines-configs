#!/bin/bash
{{ ansible_managed | comment }}

REMOTE_NAME="{{ gdrive__remote_name }}"

# shellcheck disable=SC2034,SC2206
SYNC_LOCALS=( {% for p in gdrive__sync_pairs_resolved %}{{ p.local | to_json }} {% endfor %})
# shellcheck disable=SC2034,SC2206
SYNC_REMOTES=( {% for p in gdrive__sync_pairs_resolved %}{{ p.remote | to_json }} {% endfor %})

find_pair_index() {
  local tdir="${1:-}"
  tdir="${tdir%/}"
  local best_i=-1
  local best_len=0
  local i loc lnorm n
  for i in "${!SYNC_LOCALS[@]}"; do
    loc="${SYNC_LOCALS[$i]}"
    lnorm="${loc%/}"
    if [[ "$tdir" == "$lnorm" || "$tdir" == "$lnorm"/* ]]; then
      # Semicolon keeps the following if on this line (Ansible Jinja trim_blocks)
      n={% raw %}${#lnorm}{% endraw %}; if [[ $n -gt $best_len ]]; then
        best_len=$n
        best_i=$i
      fi
    fi
  done
  echo "$best_i"
}

# Transmission: move finished torrent tree to the matching gdrive root
if [[ -n "${TR_TORRENT_DIR:-}" ]]; then
  UPLOAD_SRC="$TR_TORRENT_DIR"
  echo "Uploading finished torrent: $TR_TORRENT_NAME ($TR_TORRENT_DIR)"
  pair_idx=$(find_pair_index "$TR_TORRENT_DIR")
  if [[ "$pair_idx" -lt 0 ]]; then
    echo "ERROR: TR_TORRENT_DIR is not under any gdrive sync local path" >&2
    exit 1
  fi
  REM_DIR="${SYNC_REMOTES[$pair_idx]}"
  echo "Target remote: $REMOTE_NAME:$REM_DIR"
  rclone move "$UPLOAD_SRC" "$REMOTE_NAME:$REM_DIR" \
    --transfers 4 \
    --checkers 8 \
    --exclude "*.part" \
    --log-file "${HOME}/rclone_upload.log" \
    --log-level INFO \
    --stats 60s \
    --stats-one-line \
    --delete-empty-src-dirs
  echo "Upload finished: $TR_TORRENT_NAME -> $REMOTE_NAME:$REM_DIR"
else
  # Manual: move each local root to its remote
  echo "Uploading all configured pairs to Google Drive..."
  for i in "${!SYNC_LOCALS[@]}"; do
    _loc="${SYNC_LOCALS[$i]}"
    _rem="${SYNC_REMOTES[$i]}"
    echo "--- Pair $((i + 1))/{% raw %}${#SYNC_LOCALS[@]}{% endraw %}: $_loc -> $REMOTE_NAME:$_rem"
    rclone move "$_loc" "$REMOTE_NAME:$_rem" \
      --transfers 4 \
      --checkers 8 \
      --exclude "*.part" \
      --log-file "${HOME}/rclone_upload.log" \
      --log-level INFO \
      --stats 60s \
      --stats-one-line \
      --delete-empty-src-dirs || exit $?
  done
  echo "Upload finished (all pairs)."
fi
