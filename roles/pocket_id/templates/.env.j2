{{ ansible_managed | comment }}

# See https://pocket-id.org/docs/configuration/environment-variables

APP_URL={{ pocket_id__app_url | default("https://" ~ pocket_id__domain, true) }}

{% if pocket_id__encryption_key_file is defined and pocket_id__encryption_key_file | length > 0 -%}
ENCRYPTION_KEY_FILE={{ pocket_id__encryption_key_file }}
{%- else -%}
ENCRYPTION_KEY={{ pocket_id__encryption_key }}
{%- endif %}

TRUST_PROXY={{ pocket_id__trust_proxy | string | lower }}
MAXMIND_LICENSE_KEY={{ pocket_id__maxmind_license_key }}
PUID={{ pocket_id__puid }}
PGID={{ pocket_id__pgid }}
